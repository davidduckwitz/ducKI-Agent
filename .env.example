# DucKI Node - AI Coding Agent

# LLM Provider Configuration
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=lmstudio-community/Meta-Llama-3-8B-Instruct-GGUF

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3-5-sonnet

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Default Provider (lmstudio | openrouter | openai | ollama)
DEFAULT_PROVIDER=lmstudio

# Server Configuration
PORT=3001
HOST=127.0.0.1
NODE_ENV=development

# Database
DATABASE_PATH=./storage/ducki.db

# Storage Paths
STORAGE_PATH=./storage
PROJECTS_PATH=./projects
PLUGINS_PATH=./plugins

# Logging
LOG_LEVEL=info
LOG_FILE=./storage/logs/ducki.log

# Agent Configuration
AGENT_MAX_ITERATIONS=50
AGENT_TIMEOUT_MS=300000

# MCP Configuration
MCP_SERVER_URL=http://localhost:3002

# Local Speech-to-Text (offline, no external provider)
# Example whisper.cpp:
# LOCAL_STT_COMMAND=whisper-cli
# LOCAL_STT_ARGS=-m C:/models/ggml-base.en.bin -f {input}
#
# Placeholders:
# {input}  -> temporary audio file path
# {output} -> temporary output text file path (use this if your CLI writes files)
LOCAL_STT_COMMAND=C:/tools/whispercpp/whisper-cli.exe
LOCAL_STT_ARGS=-m C:/tools/whispercpp/models/ggml-base.bin -f {input} -otxt -of {outputBase} -l de
LOCAL_STT_INPUT_EXT=ogg
LOCAL_STT_TIMEOUT_MS=180000

DISCORD_VOICE_STT_PROVIDER=local
DISCORD_VOICE_STT_COMMAND=C:/tools/whispercpp/whisper-cli.exe
DISCORD_VOICE_STT_ARGS=-m C:/tools/whispercpp/models/ggml-base.bin -f {input} -otxt -of {outputBase} -l de
DISCORD_VOICE_STT_TIMEOUT_MS=180000

# Speech-to-Text Provider Default
# openai | ollama | silero | local | nodejs-whisper
DEFAULT_SPEECH_TO_TEXT_PROVIDER=local

# nodejs-whisper settings (if DISCORD_VOICE_STT_PROVIDER=nodejs-whisper)
NODEJS_WHISPER_MODEL_NAME=base
NODEJS_WHISPER_MODEL_ROOT_PATH=
NODEJS_WHISPER_AUTO_DOWNLOAD=true
NODEJS_WHISPER_USE_CUDA=false
NODEJS_WHISPER_LANGUAGE=de
NODEJS_WHISPER_TIMEOUT_MS=180000
NODEJS_WHISPER_INPUT_EXT=ogg